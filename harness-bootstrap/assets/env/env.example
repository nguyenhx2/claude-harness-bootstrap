# .env.example - {{PROJECT_NAME}}
#
# Placeholders only. NEVER commit a real value to this file.
# Every variable below is commented with what consumes it and where the real value comes from
# per environment. If a variable is not consumed by code that exists, delete it: an .env.example
# that lists variables nobody reads is a map of a territory that is not there.
#
# Copy to .env for local development. .env is gitignored and is never read by CI - CI injects
# its values from platform secrets.

# ---- Application ----------------------------------------------------------
# Consumed by: the app entrypoint. Source: local = this file; deployed = platform variables.
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug
PORT=3000

{{#IF_DB}}
# ---- Database -------------------------------------------------------------
# Consumed by: {{ORM}}. Source: local = a local container; staging/prod = platform secret store.
# Never point a local .env at a production database. The seed script refuses non-local targets.
DATABASE_URL=postgresql://user:password@localhost:5432/{{PROJECT_SLUG}}_dev
{{/IF_DB}}
{{#IF_AI}}
# ---- Model provider -------------------------------------------------------
# Consumed by: the provider client layer. Source: the provider console; rotate on exposure.
# This key is a spend authority, not just an identity - scope it to the minimum the app needs.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
{{/IF_AI}}
{{#IF_UI}}
# ---- Public / client-exposed ----------------------------------------------
# WARNING: anything prefixed for client exposure ships to the browser and is PUBLIC.
# Never put a secret behind a public prefix. If it must stay secret, it must stay server-side.
PUBLIC_API_BASE_URL=http://localhost:3000
{{/IF_UI}}

# ---- Integrations ---------------------------------------------------------
# One group per external service the code actually calls. For each variable state:
#   what reads it, where the real value comes from per environment, and whether it is a secret.
# Derive this list from the config reads found in the source (process.env / os.environ / viper /
# System.getenv), never from guesswork.
